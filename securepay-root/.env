# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=securepay
DB_USER=securepay_user
DB_PASSWORD=SecurePass123!@
DB_ADMIN_PASSWORD=AdminPass456!@

# API Gateway
GATEWAY_PORT=3000
GATEWAY_SECRET=gateway-secret-key-change-in-production

# Auth Service
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_URL=http://auth-service:3001
JWT_SECRET=jwt-secret-key-change-in-production-with-strong-random-string
JWT_EXPIRY=1h

# Transfer Service
TRANSFER_SERVICE_PORT=3002
TRANSFER_SERVICE_URL=http://transfer-service:3002

# Audit Logs Service
AUDIT_SERVICE_PORT=3003
AUDIT_SERVICE_URL=http://audit-logs:3003

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Security
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_CORS=true
CORS_ORIGIN=http://localhost:3000
